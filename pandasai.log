import pandas as pd

# 找出白细胞计数检查结果异常且不良事件中也存在白细胞相关AE的受试者
# 步骤：
# 1. 从实验室检查表中找到白细胞计数(WBC)异常的结果（LBCLSIG_STD != '01' 表示异常）
# 2. 从不良事件表中找到白细胞相关的AE（AETERM包含"白细胞"或"WBC"等关键词）
# 3. 通过SUBJID连接这两个结果，找出满足两个条件的受试者

sql_query = """
WITH abnormal_wbc_lab AS (
    SELECT DISTINCT STUDYID, SITEID, SUBJID, LBTEST, LBORRES, LBCLSIG_STD
    FROM table_80662ddd1aced8868c686a91fd82e16d
    WHERE LBTEST = '白细胞计数(WBC)' 
      AND LBCLSIG_STD != '01'  -- '01'表示正常，不等于'01'表示异常
),
wbc_related_ae AS (
    SELECT DISTINCT STUDYID, SITEID, SUBJID, AETERM
    FROM table_4f509eb66d88d731aec4c6669d6e7143
    WHERE UPPER(AETERM) LIKE '%白细胞%' 
       OR UPPER(AETERM) LIKE '%白細胞%'  -- 繁体
       OR UPPER(AETERM) LIKE '%WBC%'
       OR UPPER(AETERM) LIKE '%LEUKOCYTE%'
)
SELECT 
    aw.STUDYID,
    aw.SITEID,
    aw.SUBJID,
    aw.LBTEST,
    aw.LBORRES AS WBC_RESULT,
    aw.LBCLSIG_STD AS WBC_ABNORMAL_FLAG,
    ra.AETERM AS WBC_RELATED_AE
FROM abnormal_wbc_lab aw
INNER JOIN wbc_related_ae ra 
    ON aw.STUDYID = ra.STUDYID 
    AND aw.SITEID = ra.SITEID 
    AND aw.SUBJID = ra.SUBJID
ORDER BY aw.STUDYID, aw.SITEID, aw.SUBJID;
"""

# 执行查询
result_df = execute_sql_query(sql_query)

# 声明result变量
result = {
    "type": "dataframe",
    "value": result_df
}
