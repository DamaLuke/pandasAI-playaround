import pandas as pd

# 首先从实验室检查表中找出白细胞计数异常的结果
sql_lab = """
SELECT DISTINCT STUDYID, SITEID, SUBJID
FROM table_80662ddd1aced8868c686a91fd82e16d
WHERE LBTEST LIKE '%白细胞计数%' OR LBTEST LIKE '%WBC%'
AND LBCLSIG_STD != '01'  -- 正常为01，异常为非01
"""

# 然后从不良事件表中找出白细胞相关的不良事件
sql_ae = """
SELECT DISTINCT STUDYID, SITEID, SUBJID
FROM table_4f509eb66d88d731aec4c6669d6e7143
WHERE AETERM LIKE '%白细胞%' OR 
      AETERM LIKE '%WBC%' OR
      AETERM LIKE '%白血球%' OR
      AETERM LIKE '%中性粒细胞%' OR
      AETERM LIKE '%淋巴细胞%' OR
      AETERM LIKE '%单核细胞%' OR
      AETERM LIKE '%嗜酸性粒细胞%' OR
      AETERM LIKE '%嗜碱性粒细胞%'
"""

# 执行查询
df_lab_abnormal = execute_sql_query(sql_lab)
df_ae_leukocyte = execute_sql_query(sql_ae)

# 找出同时满足两个条件的受试者（交集）
if not df_lab_abnormal.empty and not df_ae_leukocyte.empty:
    # 合并STUDYID, SITEID, SUBJID为唯一标识符
    lab_ids = set(zip(df_lab_abnormal['STUDYID'], df_lab_abnormal['SITEID'], df_lab_abnormal['SUBJID']))
    ae_ids = set(zip(df_ae_leukocyte['STUDYID'], df_ae_leukocyte['SITEID'], df_ae_leukocyte['SUBJID']))
    
    # 找出交集
    common_ids = lab_ids.intersection(ae_ids)
    
    if common_ids:
        # 将结果转换为DataFrame
        result_list = []
        for studyid, siteid, subjid in common_ids:
            result_list.append({
                'STUDYID': studyid,
                'SITEID': siteid,
                'SUBJID': subjid
            })
        result_df = pd.DataFrame(result_list)
        result = {"type": "dataframe", "value": result_df}
    else:
        result = {"type": "string", "value": "没有找到同时满足白细胞计数异常且存在白细胞相关不良事件的受试者"}
else:
    result = {"type": "string", "value": "没有找到符合条件的受试者"}

# Declare result var
result
