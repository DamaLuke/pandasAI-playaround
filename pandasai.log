import pandas as pd

# 1. 从实验室检查表中找出白细胞计数(WBC)异常的结果
# 条件: LBTEST='白细胞计数(WBC)' 且 LBCLSIG='异常无临床意义' 或 '异常有临床意义'
wbc_abnormal_query = """
SELECT DISTINCT STUDYID, SITEID, SUBJID
FROM table_80662ddd1aced8868c686a91fd82e16d
WHERE LBTEST = '白细胞计数(WBC)' 
  AND LBCLSIG IN ('异常无临床意义', '异常有临床意义')
"""

wbc_abnormal_df = execute_sql_query(wbc_abnormal_query)

# 2. 从不良事件表中找出包含"白细胞"相关AE的受试者
# 查找AETERM中包含"白细胞"的不良事件
wbc_ae_query = """
SELECT DISTINCT STUDYID, SITEID, SUBJID
FROM table_4f509eb66d88d731aec4c6669d6e7143
WHERE AETERM LIKE '%白细胞%'
"""

wbc_ae_df = execute_sql_query(wbc_ae_query)

# 3. 找出同时满足两个条件的受试者
if not wbc_abnormal_df.empty and not wbc_ae_df.empty:
    # 使用SQL进行内连接，找出同时出现在两个表中的受试者
    combined_query = """
    SELECT DISTINCT a.STUDYID, a.SITEID, a.SUBJID
    FROM (
        SELECT DISTINCT STUDYID, SITEID, SUBJID
        FROM table_80662ddd1aced8868c686a91fd82e16d
        WHERE LBTEST = '白细胞计数(WBC)' 
          AND LBCLSIG IN ('异常无临床意义', '异常有临床意义')
    ) a
    INNER JOIN (
        SELECT DISTINCT STUDYID, SITEID, SUBJID
        FROM table_4f509eb66d88d731aec4c6669d6e7143
        WHERE AETERM LIKE '%白细胞%'
    ) b
    ON a.STUDYID = b.STUDYID 
    AND a.SITEID = b.SITEID 
    AND a.SUBJID = b.SUBJID
    """
    
    result_df = execute_sql_query(combined_query)
else:
    result_df = pd.DataFrame(columns=['STUDYID', 'SITEID', 'SUBJID'])

# 4. 汇总结果显示
if not result_df.empty:
    subjects_count = len(result_df)
    subjects_list = ", ".join(result_df['SUBJID'].tolist())
    
    summary_text = f"找到 {subjects_count} 名符合条件的受试者:\n"
    summary_text += f"受试者代码: {subjects_list}\n\n"
    summary_text += "详细列表如下:"
else:
    summary_text = "未找到符合条件的受试者。"

# Declare result var: 
result = {
    "type": "dataframe",
    "value": result_df
}
