import pandas as pd
sql_lab_abnormal = """
SELECT DISTINCT STUDYID, SITEID, SUBJID
FROM table_80662ddd1aced8868c686a91fd82e16d
WHERE LBTEST LIKE '%白细胞计数%' OR LBTEST LIKE '%WBC%'
  AND (LBCLSIG_STD = '02' OR LBCLSIG = '异常无临床意义' OR LBCLSIG = '异常有临床意义')
"""
sql_ae_wbc = """
SELECT DISTINCT STUDYID, SITEID, SUBJID
FROM table_4f509eb66d88d731aec4c6669d6e7143
WHERE (AETERM LIKE '%白细胞%' OR AETERM LIKE '%WBC%' OR 
       AETERM LIKE '%中性粒细胞%' OR AETERM LIKE '%粒细胞%' OR
       AETERM LIKE '%leukocyte%' OR AETERM LIKE '%white blood cell%')
"""
sql_final = f"""
SELECT lb.STUDYID, lb.SITEID, lb.SUBJID,
       COUNT(DISTINCT CASE WHEN (lb.LBTEST LIKE '%白细胞计数%' OR lb.LBTEST LIKE '%WBC%') AND 
            (lb.LBCLSIG_STD = '02' OR lb.LBCLSIG = '异常无临床意义' OR lb.LBCLSIG = '异常有临床意义') 
            THEN lb.SerialNumber END) as abnormal_wbc_count,
       COUNT(DISTINCT ae.SerialNumber) as wbc_related_ae_count
FROM ({sql_lab_abnormal}) as lb
INNER JOIN ({sql_ae_wbc}) as ae
    ON lb.STUDYID = ae.STUDYID 
    AND lb.SITEID = ae.SITEID 
    AND lb.SUBJID = ae.SUBJID
GROUP BY lb.STUDYID, lb.SITEID, lb.SUBJID
ORDER BY lb.STUDYID, lb.SITEID, lb.SUBJID
"""
result_df = execute_sql_query(sql_final)
result = {'type': 'dataframe', 'value': result_df}

